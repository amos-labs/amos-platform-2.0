# AMOS Docker Development Environment
# =====================================
# Copy to .env when using docker compose.
# For native dev (no Docker), use .env.example instead.

# ── Infrastructure ───────────────────────────────────────────────────
POSTGRES_USER=amos
POSTGRES_PASSWORD=amos_dev_password
POSTGRES_DB=amos_development
ENVIRONMENT=development

# ── Container runtime socket ────────────────────────────────────────
# Platform uses this to provision harness containers via Bollard.
# macOS Docker Desktop: /var/run/docker.sock (default)
# macOS Podman:         /run/user/501/podman/podman.sock
# Linux Docker:         /var/run/docker.sock (default)
# Linux Podman:         /run/user/$(id -u)/podman/podman.sock
DOCKER_SOCK=/var/run/docker.sock

# ── AWS Bedrock (required for AI) ───────────────────────────────────
# Get these from AWS IAM console. Needs bedrock:InvokeModel permission.
# Leave blank to start services without AI (health checks still work).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
DEFAULT_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── Auth ─────────────────────────────────────────────────────────────
AUTH_JWT_SECRET=dev_jwt_secret_change_in_prod

# ── Vault ────────────────────────────────────────────────────────────
# Stable dev key so encrypted data survives container restarts.
# Generate a new one for production: openssl rand -base64 32
VAULT_MASTER_KEY=fddcNAcyrkZ7eC9vgMXfRtTGtVAQZT8sost219njm10=

# ── Stripe billing (optional) ───────────────────────────────────────
# Leave blank to bypass all billing gates (free tier, unlimited).
# Set to enable per-harness billing in the platform dashboard.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SMALL=price_1TJzUOGlkubafVtvglhkzbQf
STRIPE_PRICE_MEDIUM=price_1TK0NjGlkubafVtvbJuzot1z
STRIPE_PRICE_LARGE=price_1TK0NlGlkubafVtvuJOxntmQ

# ── Solana (optional — needed for bounty settlement) ────────────────
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com

# ── Relay ────────────────────────────────────────────────────────────
RELAY_API_KEY=dev_relay_key_change_in_prod

# ── Customer (standalone mode) ──────────────────────────────────────
CUSTOMER_ID=dev-customer-001
CUSTOMER_NAME=Development Customer

# ── Logging ──────────────────────────────────────────────────────────
RUST_LOG=info
RUST_BACKTRACE=1
