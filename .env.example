# AMOS Harness - Local Development Configuration
# Copy to .env and adjust values for your environment.
# Config uses AMOS__ prefix with __ as nested separator.

# Database (PostgreSQL)
AMOS__DATABASE__URL=postgres://your_user@localhost:5432/amos_harness_development

# Redis
AMOS__REDIS__URL=redis://127.0.0.1:6379

# Server
AMOS__SERVER__HOST=0.0.0.0
AMOS__SERVER__PORT=3000

# AWS Bedrock - reads from ~/.aws/credentials + ~/.aws/config automatically
# Set profile if not using default:
# AWS_PROFILE=your-profile

# Agent loop
AMOS__AGENT__MAX_ITERATIONS=25
AMOS__AGENT__MAX_CONTEXT_TOKENS=200000
